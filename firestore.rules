rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} { 
      allow read, write: if false; 
    }
    
    // Core Helpers
    function isSignedIn() { 
      return request.auth != null; 
    }
    
    function incoming() { 
      return request.resource.data; 
    }
    
    function existing() { 
      return resource.data; 
    }
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    // Entity Validation Helpers
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'createdAt']) 
        && data.keys().size() <= 7
        && data.email is string && data.email.size() <= 256
        && (data.get('displayName', '') is string && data.get('displayName', '').size() <= 128)
        && (data.get('focusGoal', '') is string && data.get('focusGoal', '').size() <= 160)
        && (data.get('experienceLevel', '') is string && data.get('experienceLevel', '').size() <= 64)
        && (data.get('weeklyCommitment', '') is string && data.get('weeklyCommitment', '').size() <= 64)
        && (data.get('preferredSession', '') is string && data.get('preferredSession', '').size() <= 96)
        && data.createdAt == request.time;
    }

    function isValidSubscription(data) {
      return data.keys().hasAll(['email', 'createdAt'])
        && data.keys().size() == 2
        && data.email is string && data.email.size() <= 256
        && data.createdAt == request.time;
    }

    function isValidEnrollment(data) {
      return data.keys().hasAll(['courseId', 'courseName', 'progress', 'lastAccessedAt', 'enrolledAt'])
        && data.keys().size() == 12
        && data.courseId is string && data.courseId.size() <= 128
        && data.courseName is string && data.courseName.size() <= 128
        && data.summary is string && data.summary.size() <= 240
        && data.track is string && data.track.size() <= 80
        && data.difficulty is string && data.difficulty.size() <= 40
        && data.durationMinutes is number && data.durationMinutes >= 1 && data.durationMinutes <= 10000
        && data.progress is number && data.progress >= 0 && data.progress <= 100
        && data.currentModuleId is string && data.currentModuleId.size() <= 128
        && data.completedModuleIds is list && data.completedModuleIds.size() <= 32
        && (
          data.status == 'not_started'
          || data.status == 'in_progress'
          || data.status == 'completed'
        )
        && data.lastAccessedAt == request.time
        && data.enrolledAt == request.time;
    }

    function isValidModuleNotes(notes) {
      return notes is map
        && notes.keys().size() <= 64;
    }

    // Feature: Users
    match /users/{userId} {
      allow get: if isSignedIn() && isValidId(userId) && request.auth.uid == userId;
      allow create: if isSignedIn() 
        && isValidId(userId)
        && request.auth.uid == userId 
        && isValidUser(incoming());
      // Updates allowed only for display name
      allow update: if isSignedIn() 
        && isValidId(userId)
        && request.auth.uid == userId 
        && incoming().diff(existing()).affectedKeys().hasOnly([
          'displayName',
          'focusGoal',
          'experienceLevel',
          'weeklyCommitment',
          'preferredSession'
        ])
        && incoming().email == existing().email
        && incoming().createdAt == existing().createdAt
        && (incoming().get('displayName', '') is string && incoming().get('displayName', '').size() <= 128)
        && (incoming().get('focusGoal', '') is string && incoming().get('focusGoal', '').size() <= 160)
        && (incoming().get('experienceLevel', '') is string && incoming().get('experienceLevel', '').size() <= 64)
        && (incoming().get('weeklyCommitment', '') is string && incoming().get('weeklyCommitment', '').size() <= 64)
        && (incoming().get('preferredSession', '') is string && incoming().get('preferredSession', '').size() <= 96);
      
      // Sub-Collection: Enrollments
      match /enrollments/{enrollmentId} {
        allow read: if isSignedIn() && isValidId(userId) && request.auth.uid == userId;
        allow create: if isSignedIn() 
          && isValidId(userId) && isValidId(enrollmentId)
          && request.auth.uid == userId 
          && isValidEnrollment(incoming());
        allow update: if isSignedIn() 
          && isValidId(userId) && isValidId(enrollmentId)
          && request.auth.uid == userId 
          && incoming().diff(existing()).affectedKeys().hasOnly([
            'progress',
            'lastAccessedAt',
            'currentModuleId',
            'completedModuleIds',
            'moduleNotes',
            'status'
          ])
          && incoming().progress is number && incoming().progress >= 0 && incoming().progress <= 100
          && incoming().currentModuleId is string && incoming().currentModuleId.size() <= 128
          && incoming().completedModuleIds is list && incoming().completedModuleIds.size() <= 32
          && (
            incoming().status == 'not_started'
            || incoming().status == 'in_progress'
            || incoming().status == 'completed'
          )
          && isValidModuleNotes(incoming().get('moduleNotes', {}))
          && incoming().lastAccessedAt == request.time
          && incoming().courseId == existing().courseId
          && incoming().courseName == existing().courseName
          && incoming().enrolledAt == existing().enrolledAt
          && incoming().get('summary', '') == existing().get('summary', '')
          && incoming().get('track', '') == existing().get('track', '')
          && incoming().get('difficulty', '') == existing().get('difficulty', '')
          && incoming().get('durationMinutes', 0) == existing().get('durationMinutes', 0);
      }
    }

    // Feature: Subscriptions (Newsletter)
    match /subscriptions/{subscriptionId} {
      // Create allowed for anyone (even unauthenticated) for the newsletter landing page
      allow create: if isValidId(subscriptionId) && isValidSubscription(incoming());
    }

    // -------------------------------------------------------------------------
    // Arrears Ledger — Money Collections
    //
    // Security posture:
    //   • All money writes go through Cloud Functions (service account).
    //     Client-side writes are rejected for every collection below.
    //   • Students / tutors may read their own documents only.
    //   • creditAppliedAt may NEVER be written by the client — only the
    //     Functions service account (implicitly enforced by denying all client
    //     writes to payment_orders).
    //   • audit_log is insert-only by the service account; clients cannot read.
    // -------------------------------------------------------------------------

    // payment_orders/{invoice}
    // Read: the owning student only.
    // Write: Cloud Functions service account only (no client writes).
    match /payment_orders/{invoice} {
      allow get: if isSignedIn()
        && isValidId(invoice)
        && resource.data.studentUid == request.auth.uid;
      allow list: if isSignedIn()
        && request.query.limit <= 50
        && resource.data.studentUid == request.auth.uid;
      // All writes are via Cloud Functions — deny direct client writes.
      allow write: if false;
    }

    // arrears_invoices/{invoiceId}
    // Read: the owning student (own invoices) or admin (custom claim).
    // Write: Cloud Functions only.
    match /arrears_invoices/{invoiceId} {
      allow get: if isSignedIn()
        && isValidId(invoiceId)
        && (resource.data.studentUid == request.auth.uid
            || request.auth.token.get('admin', false) == true);
      allow list: if isSignedIn()
        && request.query.limit <= 500
        && (
          request.auth.token.get('admin', false) == true
          || resource.data.studentUid == request.auth.uid
        );
      allow write: if false;
    }

    // student_balances/{studentUid}
    // Read: the student whose balance it is, or admin.
    // Write: Cloud Functions only — this is a projection; never written by client.
    match /student_balances/{studentUid} {
      allow get: if isSignedIn()
        && isValidId(studentUid)
        && (request.auth.uid == studentUid
            || request.auth.token.get('admin', false) == true);
      allow write: if false;
    }

    // tutor_earnings_ledger/{lessonId}
    // Read: the tutor whose lesson it is, or admin.
    // Write: Cloud Functions only (append-only; no client mutations).
    match /tutor_earnings_ledger/{lessonId} {
      allow get: if isSignedIn()
        && isValidId(lessonId)
        && (resource.data.tutorUid == request.auth.uid
            || request.auth.token.get('admin', false) == true);
      allow list: if isSignedIn()
        && request.query.limit <= 100
        && (
          request.auth.token.get('admin', false) == true
          || resource.data.tutorUid == request.auth.uid
        );
      allow write: if false;
    }

    // tutor_earnings_summary/{tutorUid}
    // Read: the tutor themselves, or admin.
    // Write: Cloud Functions only.
    match /tutor_earnings_summary/{tutorUid} {
      allow get: if isSignedIn()
        && isValidId(tutorUid)
        && (request.auth.uid == tutorUid
            || request.auth.token.get('admin', false) == true);
      allow write: if false;
    }

    // payout_requests/{requestId}
    // Read: the requesting tutor, or admin.
    // Write: Cloud Functions only.
    match /payout_requests/{requestId} {
      allow get: if isSignedIn()
        && isValidId(requestId)
        && (resource.data.tutorUid == request.auth.uid
            || request.auth.token.get('admin', false) == true);
      allow list: if isSignedIn()
        && request.query.limit <= 200
        && (
          request.auth.token.get('admin', false) == true
          || resource.data.tutorUid == request.auth.uid
        );
      allow write: if false;
    }

    // audit_log/{entry}
    // Append-only by Cloud Functions service account.
    // No client read or write.
    match /audit_log/{entry} {
      allow read, write: if false;
    }
  }
}
